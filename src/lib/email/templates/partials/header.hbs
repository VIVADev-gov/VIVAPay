{{!-- partial: header --}}
{{!-- Uso: {{> header nombreEmpresa="VIVA" badge="Acción requerida" titulo="Título" subtitulo="..."}} --}}

{{> styles}}

<!-- HEADER -->
<tr>
  <td
    style="background-color:#166534; border-radius:12px 12px 0 0; padding:32px 36px; background-image:linear-gradient(135deg,#166534 0%,#16a34a 100%);">
    <!--[if mso]>
            <td style="background-color:#166534; border-radius:12px 12px 0 0; padding:32px 36px;">
            <![endif]-->

    {{#if badge}}
    <table cellpadding="0" cellspacing="0" role="presentation">
      <tr>
        <td
          style="background-color:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.2); border-radius:20px; padding:4px 12px; margin-bottom:16px;">
          <p
            style="font-family:'Inter',Arial,sans-serif; font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#bbf7d0; margin:0;">
            ● {{badge}}</p>
        </td>
      </tr>
    </table>
    <div style="height:16px;"></div>
    {{/if}}

    <div style="margin-bottom: 16px;">
      <img src="cid:logoviva" alt="VIVA Logo" style="height: 80px; width: auto; display: block; border-radius: 12px;" />
    </div>

    {{#if titulo}}
    <h1 class="email-header-title"
      style="font-family:'Inter',Arial,sans-serif; font-size:22px; font-weight:700; color:#ffffff; line-height:1.3; margin:0 0 8px 0;">
      {{titulo}}</h1>
    {{/if}}

    <p style="font-family:'Inter',Arial,sans-serif; font-size:12px; color:rgba(255,255,255,0.55); margin:0;">
      {{#if subtitulo}}{{subtitulo}}{{else}}Notificación automática del sistema · No responder{{/if}}
    </p>

  </td>
</tr>