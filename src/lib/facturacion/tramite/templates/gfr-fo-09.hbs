<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>GFR-FO-09</title>
  <style>
    @page { size: A4; margin: 18mm; }
    body { font-family: Arial, sans-serif; font-size: 11pt; color: #111; }
    h1 { font-size: 14pt; text-align: center; margin: 0 0 12px; }
    .meta { margin-bottom: 16px; font-size: 10pt; }
    .meta p { margin: 4px 0; }
    table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    th, td { border: 1px solid #333; padding: 6px 8px; vertical-align: top; }
    th { background: #eee; font-size: 10pt; }
    td.num { width: 32px; text-align: center; }
    td.estado { width: 120px; text-align: center; font-weight: bold; }
    .ok { color: #166534; }
    .no { color: #991b1b; }
    .footer { margin-top: 20px; font-size: 9pt; color: #555; }
  </style>
</head>
<body>
  <h1>{{titulo}}</h1>
  <div class="meta">
    <p><strong>Proveedor:</strong> {{proveedor}}</p>
    <p><strong>NIT:</strong> {{nit}}</p>
    <p><strong>Radicado interno:</strong> {{radicado}}</p>
    <p><strong>Fecha de generación:</strong> {{fecha}}</p>
  </div>
  <table>
    <thead>
      <tr>
        <th class="num">#</th>
        <th>Documento / requisito</th>
        <th class="estado">Estado</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td class="num">{{id}}</td>
        <td>{{label}}{{#if required}} *{{/if}}</td>
        <td class="estado {{#if cumplido}}ok{{else}}no{{/if}}">{{estado}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  <p class="footer">Checklist obligatorio completo: {{#if checklistCompleto}}Sí{{else}}No{{/if}}</p>
</body>
</html>
