MONGODB_URI=mongodb://localhost:27017/vivapay
JWT_SECRET=change-me-in-production-min-32-chars

# Superusuario de desarrollo (solo local/staging; nunca en producción)
DEV_SUPER_USER_ENABLED=false
DEV_SUPER_USER_EMAIL=dev@viva.gov.co
DEV_SUPER_USER_PASSWORD=change-me-dev-only
NEXT_PUBLIC_DEV_SUPER_USER_ENABLED=false

# Omite la ventana de fechas para enviar cuentas de cobro (solo desarrollo)
DEV_SKIP_PAYMENT_ACCOUNT_WINDOW=false
NEXT_PUBLIC_DEV_SKIP_PAYMENT_ACCOUNT_WINDOW=false

# Omite el cambio de estado al enviar al CAD; sigue enviando la notificación (solo desarrollo)
DEV_SKIP_SEND_CAD_STATE=false
NEXT_PUBLIC_DEV_SKIP_SEND_CAD_STATE=false

NEXT_PUBLIC_HOST=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remitente completo (prioridad): "Vivapay <noreply@viva.gov.co>"
SMTP_FROM=
# Nombre visible si SMTP_FROM está vacío (se combina con SMTP_USER)
SMTP_FROM_NAME=Vivapay

# Buzón del CAD: formularios de cuenta de cobro y trámites de facturación
EMAIL_CAD=

# GFR-FO-11: UVT y años de referencia (montos los ingresa cada contratista)
GFR_FO_11_UVT_PREVIOUS=35607
GFR_FO_11_UVT_CURRENT=36308
# GFR_FO_11_YEAR_PREVIOUS=2025
# GFR_FO_11_YEAR_CURRENT=2026

# LibreOffice headless para convertir formularios Excel a PDF
LIBREOFFICE_BIN=/usr/bin/soffice
